# Copy to ".env" next to docker-compose.yml and fill in.
# Values are literal: NO surrounding quotes, and special characters (incl. $) need no escaping.
# (On the NAS /volume1/docker share, chmod 600 EPERMs — Synology ACL already gates reads to root.)
#
# Use the SECOND IBKR username you created for the Gateway — NOT your main login.
# (Logging your main user into Gateway would boot your web/mobile session.)
TWS_USERID=your_gateway_username
TWS_PASSWORD=your_gateway_password

# Paper account id — starts with "DU". Find it in Client Portal or TWS once logged in.
IB_ACCOUNT_ID=DU1234567

# Password for the Gateway's VNC server, used once to approve the first-login 2FA push.
VNC_SERVER_PASSWORD=choose_something
